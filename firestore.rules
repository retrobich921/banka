rules_version = '2';

// Per-feature правила. Базовое требование `request.auth != null` сохраняется,
// но конкретные коллекции получают точечные ограничения.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Проверяет, является ли текущий пользователь владельцем группы.
    // Используется для одобрения запросов на вступление в закрытые группы.
    function isGroupOwner(groupId) {
      return isSignedIn() && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }
    // Может ли текущий пользователь публиковать посты в группу: политика
    // `all` (или отсутствует — легаси-группы) разрешает всем участникам,
    // `admins` — только владельцу и админам из денорм-массива adminsUids.
    function canPostToGroup(groupId) {
      let g = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return g.get('postingPolicy', 'all') != 'admins'
        || g.ownerId == request.auth.uid
        || request.auth.uid in g.get('adminsUids', []);
    }

    // ---- users/{uid} (Sprint 3) ---------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    // ---- groups/{groupId} (Sprint 5) ----------------------------------------
    match /groups/{groupId} {
      allow read: if isSignedIn();

      // Создавать группу может только авторизованный, при этом ownerId должен
      // совпадать с auth.uid и денорм-массив membersUids — содержать его.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.membersUids;

      // Редактировать metadata разрешено только владельцу.
      // Обновление membersUids/membersCount при join/leave разрешено всем.
      // Обновление postsCount при создании поста разрешено всем.
      allow update: if isSignedIn() && (
        // Владелец может менять любые поля
        resource.data.ownerId == request.auth.uid
        // Или это операция join/leave (меняются только membersUids, membersCount, updatedAt)
        || (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['membersUids', 'membersCount', 'updatedAt'])
        )
        // Или это инкремент postsCount при создании поста (меняются только postsCount, updatedAt)
        || (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['postsCount', 'updatedAt'])
        )
      );

      // Удалять только владельцу.
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      // ---- members/{uid} ----------------------------------------------------
      match /members/{memberId} {
        allow read: if isSignedIn();

        // Пользователь может создать собственный member-документ (вступить в публичную группу)
        // ИЛИ владелец группы может создать member-документ для другого пользователя
        // (при одобрении запроса на вступление в закрытую группу).
        allow create: if isSelf(memberId) || isGroupOwner(groupId);
        
        // Пользователь может удалить собственный member-документ (выйти из группы).
        allow delete: if isSelf(memberId);

        // Менять роль может только владелец группы.
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
            == request.auth.uid;
      }

      // ---- join_requests/{userId} -------------------------------------------
      match /join_requests/{userId} {
        allow read: if isSignedIn();
        
        // Создавать запрос может только сам пользователь (userId = ID документа)
        // groupOwnerId должен быть строкой
        allow create: if isSignedIn() 
          && request.auth.uid == userId
          && request.resource.data.groupOwnerId is string
          && request.resource.data.groupOwnerId.size() > 0;
        
        // Обновлять (одобрять/отклонять) может только владелец группы
        // Проверяем по полю groupOwnerId в самом документе запроса
        allow update: if isSignedIn()
          && resource.data.groupOwnerId == request.auth.uid;
        
        // Удалять может сам пользователь или владелец группы
        allow delete: if isSignedIn() && (
          request.auth.uid == userId
          || resource.data.groupOwnerId == request.auth.uid
        );
      }
    }

    // ---- posts/{postId} (Sprint 7) -----------------------------------------
    match /posts/{postId} {
      allow read: if isSignedIn();

      // Создавать пост может только сам автор. Денорм-счётчики
      // likesCount / commentsCount должны стартовать с нуля.
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.drinkType is string
        // Оценка необязательна; если есть — это map с числовым ratingScore.
        && (!('rating' in request.resource.data)
            || request.resource.data.rating is map)
        // Пост в группу — только если политика группы это разрешает.
        && (!('groupId' in request.resource.data)
            || canPostToGroup(request.resource.data.groupId));

      // Редактирование текстовых полей — только автор.
      // Счётчики (likesCount, commentsCount) могут обновляться любым авторизованным
      // (при лайке/комментировании).
      allow update: if isSignedIn() && (
        // Автор может менять любые поля
        resource.data.authorId == request.auth.uid
        // Или это обновление счётчиков (меняются только likesCount/commentsCount)
        || (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['likesCount', 'commentsCount'])
        )
        // Или это бэкфилл-миграция: проставление drinkId старым постам
        // (см. DrinkBackfill). Меняется только это поле.
        || (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['drinkId'])
        )
      );

      // Удалять — только автор. Каскадное удаление подколлекций
      // (likes / comments) сделает Cloud Function в Sprint 10/11.
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // ---- likes/{userId} (Sprint 10) ---------------------------------------
      // Лайк живёт под постом, id документа = uid лайкнувшего. Поставить /
      // снять лайк может только сам пользователь, читать — любой авторизованный
      // (нужно для экрана «Кто лайкнул» и `watchHasLiked`). Поле `likesCount`
      // у родительского поста инкрементирует Cloud Function `onLikeCreated/Deleted`.
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isSelf(userId);
        allow update: if false;
      }

      // ---- comments/{commentId} (Sprint 11) --------------------------------
      // Комментарий принадлежит автору. Создавать может любой авторизованный
      // (с обязательным authorId == auth.uid и непустым text), удалять —
      // только автор. Редактирование пока запрещено (правка текста — polish).
      // `commentsCount` инкрементирует Cloud Function `onCommentCreated/Deleted`.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow delete: if isSignedIn()
          && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    // ---- brands/{brandId} (Sprint 13) --------------------------------------
    // Справочник брендов. Читать может любой авторизованный, создавать —
    // тоже любой (через `EnsureBrand`), при этом стартовый `postsCount`
    // обязан быть 0 — счётчик инкрементирует Cloud Function
    // `onPostCreatedUpdateBrandStats`. Поля `name`/`slug` обязательны.
    // Редактирование metadata (logoUrl, country) разрешено любому
    // авторизованному (база коллективная, как `barcodes`); `postsCount`
    // на клиенте трогать нельзя — он не входит в allowedFields. Удаление
    // запрещено (бренд переживает посты).
    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0
        && request.resource.data.postsCount == 0;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['name', 'logoUrl', 'country', 'updatedAt']);
      allow delete: if false;

      // ---- flavors/{flavorId} (Sprint 15) ----------------------------------
      // Вкусы для конкретного бренда. Читать может любой авторизованный,
      // создавать тоже любой (коллективная база вкусов для каждого бренда).
      // Поле `name` обязательно. Редактирование и удаление пока запрещены.
      match /flavors/{flavorId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.brandId == brandId;
        allow update, delete: if false;
      }
    }

    // ---- barcodes/{ean} (Sprint 14) ----------------------------------------
    // Коллективная база штрих-кодов. Читать может любой авторизованный
    // (lookup перед созданием поста). Записывать тоже любой — но при
    // create обязательны `drinkName`/`contributedBy == auth.uid`. На
    // апдейте позволяем менять только метаданные (`drinkName`, `brandId`,
    // `brandName`, `suggestedPhotoUrl`, `createdAt` обновляется
    // serverTimestamp при merge — поэтому он в allowed). Поле
    // `contributedBy` нельзя менять чужим пользователям. Удаление
    // запрещено (база накапливается).
    match /barcodes/{ean} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.drinkName is string
        && request.resource.data.drinkName.size() > 0
        && request.resource.data.contributedBy == request.auth.uid;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly([
              'drinkName',
              'brandId',
              'brandName',
              'suggestedPhotoUrl',
              'contributedBy',
              'createdAt',
            ]);
      allow delete: if false;
    }

    // ---- users/{uid}/likedPosts/{postId} (Sprint 10) -----------------------
    // «Обратный» документ — нужен для быстрой ленты «мои лайки» в профиле
    // (Sprint 16). Записывает / удаляет только сам пользователь, читает только
    // он (приватный список).
    match /users/{userId}/likedPosts/{postId} {
      allow read: if isSelf(userId);
      allow create, delete: if isSelf(userId);
      allow update: if false;
    }

    // ---- drinks/{drinkId} — карточки напитков (агрегаты) -------------------
    // Денорм-агрегат: создаётся/обновляется клиентом в батче вместе с
    // созданием/удалением поста (инкременты счётчиков, средняя оценка).
    // Пишет любой авторизованный — данные вычислимы из постов, злоумышленник
    // максимум испортит счётчики, не чужой контент.
    match /drinks/{drinkId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.name is string;
      allow delete: if false;
    }

    // ---- meta/{docId} — служебные claim-документы клиентских миграций -----
    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    // ---- users/{uid}/following/{targetUid} — подписки на людей ------------
    // Документ-маркер «userId подписан на targetUid». Управляет только сам
    // подписчик; читать может любой авторизованный (счётчики/списки подписок).
    match /users/{userId}/following/{targetUid} {
      allow read: if isSignedIn();
      allow create, delete: if isSelf(userId);
      allow update: if false;
    }

    // ---- Fallback: по умолчанию всё, что не описано выше — закрыто.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
