rules_version = '2';

// Per-feature правила. Базовое требование `request.auth != null` сохраняется,
// но конкретные коллекции получают точечные ограничения.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- users/{uid} (Sprint 3) ---------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    // ---- groups/{groupId} (Sprint 5) ----------------------------------------
    match /groups/{groupId} {
      allow read: if isSignedIn();

      // Создавать группу может только авторизованный, при этом ownerId должен
      // совпадать с auth.uid и денорм-массив membersUids — содержать его.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.membersUids;

      // Редактировать metadata разрешено только владельцу. Денорм-счётчики
      // (membersCount/postsCount) и массив membersUids трогает только Cloud
      // Functions либо клиент через join/leave (мы это покрываем в правилах
      // ниже через `match /members`).
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      // Удалять только владельцу.
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      // ---- members/{uid} ----------------------------------------------------
      match /members/{memberId} {
        allow read: if isSignedIn();

        // Любой авторизованный может вступить (создать собственный
        // member-документ) либо самостоятельно выйти (удалить).
        allow create, delete: if isSelf(memberId);

        // Менять роль может только владелец группы.
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
            == request.auth.uid;
      }
    }

    // ---- posts/{postId} (Sprint 7) -----------------------------------------
    match /posts/{postId} {
      allow read: if isSignedIn();

      // Создавать пост может только сам автор. Денорм-счётчики
      // likesCount / commentsCount должны стартовать с нуля — реальное
      // их инкрементирование делает Cloud Functions / транзакции в
      // последующих спринтах (Sprint 10/11).
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.rarity is int
        && request.resource.data.rarity >= 1
        && request.resource.data.rarity <= 9;

      // Редактирование текстовых полей — только автор. Счётчики и
      // searchKeywords меняются Cloud Functions либо самим автором при
      // апдейте (мы пересчитываем токены на клиенте).
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // Удалять — только автор. Каскадное удаление подколлекций
      // (likes / comments) сделает Cloud Function в Sprint 10/11.
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // ---- likes/{userId} (Sprint 10) ---------------------------------------
      // Лайк живёт под постом, id документа = uid лайкнувшего. Поставить /
      // снять лайк может только сам пользователь, читать — любой авторизованный
      // (нужно для экрана «Кто лайкнул» и `watchHasLiked`). Поле `likesCount`
      // у родительского поста инкрементирует Cloud Function `onLikeCreated/Deleted`.
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isSelf(userId);
        allow update: if false;
      }
    }

    // ---- users/{uid}/likedPosts/{postId} (Sprint 10) -----------------------
    // «Обратный» документ — нужен для быстрой ленты «мои лайки» в профиле
    // (Sprint 16). Записывает / удаляет только сам пользователь, читает только
    // он (приватный список).
    match /users/{userId}/likedPosts/{postId} {
      allow read: if isSelf(userId);
      allow create, delete: if isSelf(userId);
      allow update: if false;
    }

    // ---- Fallback: по умолчанию всё, что не описано выше — закрыто.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
